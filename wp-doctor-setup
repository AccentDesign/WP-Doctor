#!/bin/bash

# WP Doctor - One-command startup
# Usage: ./wp-doctor-start [wordpress-path]
# This script checks prerequisites, sets up MCP, and launches Claude

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MCP_SERVER_DIR="$SCRIPT_DIR/mcp-server"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

echo ""
echo -e "${CYAN}╔════════════════════════════════════════╗${NC}"
echo -e "${CYAN}║       WP Doctor - Code Health          ║${NC}"
echo -e "${CYAN}╚════════════════════════════════════════╝${NC}"
echo ""

FAILED=0

# Check PHP
echo -n "  PHP............ "
if command -v php &> /dev/null; then
    echo -e "${GREEN}✓${NC} $(php -v | head -n 1 | cut -d ' ' -f 2)"
else
    echo -e "${RED}✗ Missing${NC} (brew install php)"
    FAILED=1
fi

# Check Node.js
echo -n "  Node.js........ "
if command -v node &> /dev/null; then
    echo -e "${GREEN}✓${NC} $(node -v)"
else
    echo -e "${RED}✗ Missing${NC} (brew install node)"
    FAILED=1
fi

# Check Composer
echo -n "  Composer....... "
if command -v composer &> /dev/null; then
    echo -e "${GREEN}✓${NC}"
else
    echo -e "${RED}✗ Missing${NC} (brew install composer)"
    FAILED=1
fi

# Check Claude CLI
echo -n "  Claude CLI..... "
if command -v claude &> /dev/null; then
    echo -e "${GREEN}✓${NC}"
else
    echo -e "${RED}✗ Missing${NC} (npm install -g @anthropic-ai/claude-code)"
    FAILED=1
fi

echo ""

# Exit early if prerequisites failed
if [ $FAILED -eq 1 ]; then
    echo -e "${RED}Please install missing dependencies and try again.${NC}"
    exit 1
fi

# Install MCP dependencies if needed
echo -n "  MCP deps....... "
if [ -d "$MCP_SERVER_DIR/node_modules" ]; then
    echo -e "${GREEN}✓${NC}"
else
    echo -e "${YELLOW}Installing...${NC}"
    cd "$MCP_SERVER_DIR"
    npm install --silent 2>/dev/null
    echo -e "  MCP deps....... ${GREEN}✓${NC}"
fi

# Install PHP dependencies if needed
echo -n "  PHP deps....... "
if [ -d "$SCRIPT_DIR/vendor" ]; then
    echo -e "${GREEN}✓${NC}"
else
    echo -e "${YELLOW}Installing...${NC}"
    cd "$SCRIPT_DIR"
    composer install --quiet 2>/dev/null
    echo -e "  PHP deps....... ${GREEN}✓${NC}"
fi

# Create/update .mcp.json
MCP_CONFIG="$SCRIPT_DIR/.mcp.json"
cat > "$MCP_CONFIG" << EOF
{
  "mcpServers": {
    "wp-doctor": {
      "command": "node",
      "args": ["$MCP_SERVER_DIR/index.js"]
    }
  }
}
EOF

echo -e "${GREEN}Setup complete!${NC}"
echo ""
echo "Run 'claude' to start analyzing WordPress projects."
